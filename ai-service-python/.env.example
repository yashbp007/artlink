# ─────────────────────────────────────────────────────────────────────────────
# Artist Platform — AI Service Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
# Port the FastAPI service runs on
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Spring Boot base URL. Only Spring Boot should call this service.
ALLOWED_ORIGINS=http://localhost:8080

# ── Model Pre-loading ────────────────────────────────────────────────────────
# Set to "true" to pre-load all AI models at startup (recommended for production).
# Set to "false" for faster startup during development (models load on first request).
PRELOAD_MODELS=true

# ── Model Cache Directory ─────────────────────────────────────────────────────
# HuggingFace Transformers caches downloaded models here.
# Mount as a Docker volume to avoid re-downloading on container restart.
MODEL_CACHE_DIR=./model_cache
HF_HOME=./model_cache

# Optional: HuggingFace API token (only needed for gated models, not required here)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Embedding Model ───────────────────────────────────────────────────────────
# SentenceTransformer model for creating post embeddings.
# "all-MiniLM-L6-v2" is fast (90MB) and high quality for this use case.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB (Vector Database) ───────────────────────────────────────────────
# Local persistent directory where ChromaDB stores all post vectors.
# Mount as a Docker volume to persist data across container restarts.
CHROMA_PERSIST_DIR=./chroma_data

# ── Moderation Thresholds ────────────────────────────────────────────────────
# Scores above BLOCK  threshold → BLOCK action
# Scores above REVIEW threshold → REVIEW action (send to admin queue)
# Scores below REVIEW threshold → SAFE (publish immediately)
TEXT_BLOCK_THRESHOLD=0.80
TEXT_REVIEW_THRESHOLD=0.50
IMAGE_BLOCK_THRESHOLD=0.75
IMAGE_REVIEW_THRESHOLD=0.50
